<!-- ========== PAGE: ADD NEW ========== -->
<div class="page" id="page-add">
  <div class="app-shell">
    <!-- Navbar -->
    <nav class="navbar">
      <span class="brand">ContactFlow</span>
      <div class="nav-links">
        <a href="#" class="nav-link" onclick="showPage('contacts')">Contacts</a>
        <a href="#" class="nav-link active" onclick="showPage('add')"
          >Add New</a
        >
      </div>
      <div class="avatar-btn">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="12" cy="8" r="4" />
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
        </svg>
      </div>
    </nav>

    <!-- Content -->
    <main class="main-content add-main">
      <h1 class="page-title center">Tambah Kontak Baru</h1>
      <p class="page-sub center">
        Simpan detail koneksi baru Anda dengan mudah.
      </p>

      <div class="form-card">
        <!-- Avatar Upload -->
        <div class="avatar-upload-wrap">
          <div class="avatar-upload" id="avatar-preview">
            <svg
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#94a3b8"
              stroke-width="1.5"
            >
              <circle cx="12" cy="8" r="4" />
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
            </svg>
          </div>
          <label class="avatar-cam-btn" title="Upload foto">
            <input
              type="file"
              accept="image/*"
              hidden
              onchange="previewAvatar(event)"
            />
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path
                d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"
              />
              <circle cx="12" cy="13" r="4" />
            </svg>
          </label>
        </div>

        <!-- Form -->
        <div class="form-group">
          <label class="form-label">NAMA LENGKAP</label>
          <div class="input-wrap">
            <svg
              class="input-icon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="8" r="4" />
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
            </svg>
            <input
              type="text"
              class="form-input"
              placeholder="Contoh: Budi Santoso"
            />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">EMAIL</label>
          <div class="input-wrap">
            <svg
              class="input-icon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <polyline points="2,4 12,13 22,4" />
            </svg>
            <input
              type="email"
              class="form-input"
              placeholder="budi@example.com"
            />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">NO. HANDPHONE</label>
          <div class="input-wrap">
            <svg
              class="input-icon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.8 19.8 0 0 1 1.62 3.38 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6.12 6.12l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
              />
            </svg>
            <input
              type="tel"
              class="form-input"
              placeholder="+62 812 3456 7890"
            />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">KATEGORI</label>
          <div class="category-group">
            <button class="cat-btn" onclick="selectCat(this)">Work</button>
            <button class="cat-btn" onclick="selectCat(this)">Family</button>
            <button class="cat-btn active" onclick="selectCat(this)">
              Friend
            </button>
          </div>
        </div>

        <button class="btn-primary full-btn">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path
              d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"
            />
            <polyline points="17 21 17 13 7 13 7 21" />
            <polyline points="7 3 7 8 15 8" />
          </svg>
          Simpan Kontak
        </button>

        <button class="btn-secondary full-btn" onclick="showPage('contacts')">
          Batalkan
        </button>
      </div>

      <!-- Tip -->
      <div class="tip-box">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="var(--primary)"
          stroke="none"
        >
          <path
            d="M12 2C8.13 2 5 5.13 5 9c0 2.74 1.54 5.12 3.81 6.38L9 17h6l.19-1.62C17.46 14.12 19 11.74 19 9c0-3.87-3.13-7-7-7zm1 14H11v-2h2v2zm0-4H11V7h2v6z"
          />
        </svg>
        <p>
          <strong>Tips:</strong> Menambahkan label kategori membantu Anda
          menemukan kontak lebih cepat saat daftar Anda bertambah banyak.
        </p>
      </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <span>© 2024 ContactFlow. Built for clarity.</span>
      <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Support</a>
        <a href="#">Feedback</a>
      </div>
    </footer>
  </div>
</div>
